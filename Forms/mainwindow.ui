               <widget class="QLabel" name="label_10">
                <property name="text"><string>DEADLINE</string></property>
               </widget>
              </item>
              <item>
               <widget class="QDateEdit" name="task_end">
                <property name="minimumSize"><size><width>0</width><height>28</height></size></property>
                <property name="calendarPopup"><bool>true</bool></property>
               </widget>
              </item>

              <item>
               <widget class="QLabel" name="label_12">
                <property name="text"><string>PRIORITY</string></property>
               </widget>
              </item>
              <item>
               <widget class="QComboBox" name="task_priority">
                <property name="minimumSize"><size><width>0</width><height>28</height></size></property>
                <item><property name="text"><string>SELECT PRIORITY</string></property></item>
                <item><property name="text"><string>Urgent</string></property></item>
                <item><property name="text"><string>Important</string></property></item>
                <item><property name="text"><string>Important &amp; Urgent</string></property></item>
                <item><property name="text"><string>Important NOT Urgent</string></property></item>
               </widget>
              </item>

              <!-- Small gap before button — fixed, not expanding -->
              <item>
               <spacer name="dash_formBtnSpacer">
                <property name="orientation"><enum>Qt::Orientation::Vertical</enum></property>
                <property name="sizeType"><enum>QSizePolicy::Policy::Fixed</enum></property>
                <property name="sizeHint" stdset="0"><size><width>0</width><height>6</height></size></property>
               </spacer>
              </item>

              <item>
               <widget class="QPushButton" name="btn_addtask">
                <property name="minimumSize"><size><width>0</width><height>34</height></size></property>
                <property name="text"><string>Add Task</string></property>
               </widget>
              </item>

             </layout>
            </widget>
           </item>
           <!-- END ADD TASK FORM -->

           <!-- ── AI CHATBOT LOGO BUTTON ──
                Sits in the freed space below the form.
                Clicking opens the AI Chat dialog from C++ code.
                Use setIcon() + setFixedSize() in C++ for the actual image.
                The name "btn_ai_open" is what you connect to in your slot.
           -->
           <item>
            <widget class="QFrame" name="ai_logoFrame">
             <property name="frameShape"><enum>QFrame::Shape::StyledPanel</enum></property>
             <property name="frameShadow"><enum>QFrame::Shadow::Raised</enum></property>
             <property name="sizePolicy">
              <sizepolicy hsizetype="Preferred" vsizetype="Expanding">
               <horstretch>0</horstretch>
               <verstretch>1</verstretch>
              </sizepolicy>
             </property>
             <layout class="QVBoxLayout" name="ai_logoFrameLayout">
              <property name="spacing"><number>6</number></property>
              <property name="leftMargin"><number>16</number></property>
              <property name="topMargin"><number>16</number></property>
              <property name="rightMargin"><number>16</number></property>
              <property name="bottomMargin"><number>16</number></property>

              <!-- Top spacer — centres the button vertically -->
              <item>
               <spacer name="ai_logoTopSpacer">
                <property name="orientation"><enum>Qt::Orientation::Vertical</enum></property>
                <property name="sizeType"><enum>QSizePolicy::Policy::Expanding</enum></property>
                <property name="sizeHint" stdset="0"><size><width>0</width><height>10</height></size></property>
               </spacer>
              </item>

              <!-- AI icon button — set icon in C++:
                   btn_ai_open->setIcon(QIcon(":/icons/ai_logo.png"));
                   btn_ai_open->setIconSize(QSize(52, 52));            -->
              <item>
               <layout class="QHBoxLayout" name="ai_logoRow">
                <property name="spacing"><number>0</number></property>
                <item>
                 <spacer name="ai_logoLeftSpacer">
                  <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
                  <property name="sizeType"><enum>QSizePolicy::Policy::Expanding</enum></property>
                  <property name="sizeHint" stdset="0"><size><width>10</width><height>0</height></size></property>
                 </spacer>
                </item>
                <item>
                 <widget class="QPushButton" name="btn_ai_open">
                  <property name="minimumSize"><size><width>68</width><height>68</height></size></property>
                  <property name="maximumSize"><size><width>68</width><height>68</height></size></property>
                  <!-- Fallback text shown if no icon is set -->
                  <property name="text"><string>✦ AI</string></property>
                  <property name="toolTip"><string>Open AI Assistant</string></property>
                  <property name="cursor">
                   <cursorShape>PointingHandCursor</cursorShape>
                  </property>
                 </widget>
                </item>
                <item>
                 <spacer name="ai_logoRightSpacer">
                  <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
                  <property name="sizeType"><enum>QSizePolicy::Policy::Expanding</enum></property>
                  <property name="sizeHint" stdset="0"><size><width>10</width><height>0</height></size></property>
                 </spacer>
                </item>
               </layout>
              </item>

              <!-- Caption label -->
              <item>
               <widget class="QLabel" name="ai_logo_caption">
                <property name="text"><string>AI Assistant</string></property>
                <property name="alignment"><set>Qt::AlignmentFlag::AlignHCenter</set></property>
               </widget>
              </item>

              <!-- Bottom spacer -->
              <item>
               <spacer name="ai_logoBottomSpacer">
                <property name="orientation"><enum>Qt::Orientation::Vertical</enum></property>
                <property name="sizeType"><enum>QSizePolicy::Policy::Expanding</enum></property>
                <property name="sizeHint" stdset="0"><size><width>0</width><height>10</height></size></property>
               </spacer>
              </item>

             </layout>
            </widget>
           </item>
           <!-- END AI LOGO FRAME -->

          </layout>
         </widget>
        </item>
        <!-- END RIGHT PANEL -->

       </layout>
      </widget>
      <!-- END DASHBOARD PAGE -->

     </widget>
    </item>
   </layout>
  </widget>
  <widget class="QStatusBar" name="statusbar"/>
 </widget>
